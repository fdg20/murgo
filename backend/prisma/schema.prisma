generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  MERCHANT
  RIDER
  ADMIN
}

enum MerchantStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  RIDER_ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum RiderStatus {
  OFFLINE
  ONLINE
  BUSY
}

enum NotificationType {
  ORDER_UPDATE
  PROMO
  SYSTEM
  DELIVERY
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  phone         String?
  avatarUrl     String?
  role          UserRole @default(CUSTOMER)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer?
  merchant      Merchant?
  rider         Rider?
  notifications Notification[]
  reviews       Review[]

  @@index([clerkId])
  @@index([role])
}

model Customer {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Merchant {
  id              String         @id @default(cuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String
  description     String?
  logoUrl         String?
  coverUrl        String?
  phone           String
  email           String
  address         String
  city            String
  latitude        Float
  longitude       Float
  status          MerchantStatus @default(PENDING)
  commissionRate  Float          @default(10)
  isOpen          Boolean        @default(true)
  openingTime     String?
  closingTime     String?
  products        Product[]
  categories      Category[]
  orders          Order[]
  promoCodes      PromoCode[]
  reviews         Review[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([city])
  @@index([latitude, longitude])
}

model Rider {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType     String      @default("motorcycle")
  licenseNumber   String?
  status          RiderStatus @default(OFFLINE)
  currentLat      Float?
  currentLng      Float?
  totalEarnings   Float       @default(0)
  totalDeliveries Int         @default(0)
  orders          Order[]
  trackingLocations TrackingLocation[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
}

model Category {
  id         String    @id @default(cuid())
  name       String
  merchantId String
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products   Product[]
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([merchantId, name])
}

model Product {
  id            String      @id @default(cuid())
  merchantId    String
  merchant      Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  description   String?
  imageUrl      String?
  price         Float
  discountPrice Float?
  stock         Int         @default(0)
  isAvailable   Boolean     @default(true)
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([merchantId])
  @@index([categoryId])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Home")
  street     String
  barangay   String?
  city       String
  province   String   @default("Negros Occidental")
  latitude   Float
  longitude  Float
  isDefault  Boolean  @default(false)
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  merchantId      String
  merchant        Merchant    @relation(fields: [merchantId], references: [id])
  riderId         String?
  rider           Rider?      @relation(fields: [riderId], references: [id])
  addressId       String
  address         Address     @relation(fields: [addressId], references: [id])
  status          OrderStatus @default(PENDING)
  subtotal        Float
  discount        Float       @default(0)
  deliveryFee     Float
  total           Float
  promoCodeId     String?
  promoCode       PromoCode?  @relation(fields: [promoCodeId], references: [id])
  distanceKm      Float
  notes           String?
  estimatedEta    Int?
  items           OrderItem[]
  trackingLocations TrackingLocation[]
  review          Review?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerId])
  @@index([merchantId])
  @@index([riderId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  subtotal  Float

  @@index([orderId])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENTAGE")
  discountValue Float
  minOrderAmount Float    @default(0)
  maxDiscount   Float?
  usageLimit    Int?
  usedCount     Int       @default(0)
  merchantId    String?
  merchant      Merchant? @relation(fields: [merchantId], references: [id])
  isActive      Boolean   @default(true)
  startsAt      DateTime  @default(now())
  expiresAt     DateTime?
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
}

model DeliveryFeeConfig {
  id            String   @id @default(cuid())
  name          String   @default("Default")
  baseFee       Float    @default(49)
  perKmRate     Float    @default(10)
  flatFeeKm     Float    @default(2)
  flatFeeAmount Float    @default(49)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceArea {
  id          String   @id @default(cuid())
  name        String   @unique
  province    String   @default("Negros Occidental")
  country     String   @default("Philippines")
  boundaryGeo Json
  centerLat   Float
  centerLng   Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupportedCity {
  id        String   @id @default(cuid())
  name      String   @unique
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TrackingLocation {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId   String
  rider     Rider    @relation(fields: [riderId], references: [id])
  latitude  Float
  longitude Float
  heading   Float?
  speed     Float?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([riderId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType @default(SYSTEM)
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

model Review {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([merchantId])
}

model CommissionConfig {
  id              String   @id @default(cuid())
  name            String   @default("Default")
  platformRate    Float    @default(10)
  merchantRate    Float    @default(90)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

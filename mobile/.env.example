# Use your PC's LAN IP — NOT localhost — when testing on a physical phone with Expo Go.
# Find IP: ipconfig (Windows) → IPv4 Address, e.g. 192.168.1.5
EXPO_PUBLIC_API_URL=http://YOUR_PC_IP:3000/api
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_SOCKET_URL=http://YOUR_PC_IP:3000
EXPO_PUBLIC_ADMIN_URL=http://YOUR_PC_IP:5173

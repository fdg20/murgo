# --- Live API on Render (phone can use mobile data; API does not need your PC) ---
EXPO_PUBLIC_API_URL=https://YOUR-SERVICE.onrender.com/api
EXPO_PUBLIC_SOCKET_URL=https://YOUR-SERVICE.onrender.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_ADMIN_URL=https://your-admin.vercel.app

# --- Local dev only (Expo Go + backend on your PC) ---
# Use LAN IP from ipconfig — NOT localhost — on a physical phone.
# EXPO_PUBLIC_API_URL=http://192.168.1.5:3000/api
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.5:3000
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# EXPO_PUBLIC_ADMIN_URL=http://192.168.1.5:5173

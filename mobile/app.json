{
  "expo": {
    "name": "MurGo",
    "slug": "murgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D3557"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to verify you are within Murcia and to track deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Riders need location access for live delivery tracking within Murcia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D3557",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MurGo to use your location for delivery tracking within Murcia."
        }
      ]
    ]
  }
}
